{
  "name": "multi-tool-vscode",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "publisher": "yuyu-umehara",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "tool",
    "text",
    "transform",
    "calculator",
    "productivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yuyu-umehara/MultiTool.git"
  },
  "icon": "images/icon.png",
  "license": "MIT",
  "l10n": "./l10n/bundle.l10n.json",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "multi-tool-container",
          "title": "%view.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "multi-tool-container": [
        {
          "type": "webview",
          "id": "multi-tool-sidebar",
          "name": "%view.name%",
          "icon": "$(tools)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "multi-tool.toggleDescriptions",
          "when": "view == multi-tool-sidebar",
          "group": "navigation@1"
        },
        {
          "command": "multi-tool.addTool",
          "when": "view == multi-tool-sidebar",
          "group": "navigation@2"
        }
      ]
    },
    "commands": [
      {
        "command": "multi-tool.addTool",
        "title": "%command.addTool%",
        "icon": "$(add)"
      },
      {
        "command": "multi-tool.editTool",
        "title": "%command.editTool%"
      },
      {
        "command": "multi-tool.deleteTool",
        "title": "%command.deleteTool%"
      },
      {
        "command": "multi-tool.toggleDescriptions",
        "title": "%command.toggleDescriptions%",
        "icon": "$(info)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "20.2.5",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {}
}
